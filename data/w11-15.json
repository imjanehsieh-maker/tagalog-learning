  "grammar": [
    {
      "wk": 11,
      "keyword": "Kailangan",
      "reading": "凱拉安",
      "meaning": "需要 / 必須",
      "mnemonic": "凱拉安≈你需要安慰，凱旋的拉安",
      "formulas": [
        "需要東西：Kailangan + 所有格 + ng + 東西",
        "需要做事：Kailangan + 所有格 + ng + 動詞（口語常縮略：ko+ng=kong）",
        "被需要：Kailangan + 主格代詞（Kailangan ako.）"
      ],
      "examples": [
        { "tl": "Kailangan ko ng kape.", "cn": "我需要咖啡。" },
        { "tl": "Kailangan kong kumain.", "cn": "我需要吃東西。" },
        { "tl": "Kailangan kita.", "cn": "我需要你。" },
        { "tl": "Kailangan namin ng tulong.", "cn": "我們需要幫助。" }
      ],
      "tip": "Kailangan=實際需要；Dapat=道義應該；Gusto=想要偏好。三個不一樣！",
      "table": {
        "headers": ["代詞", "Tagalog", "中文"],
        "rows": [
          ["我", "Kailangan ko", "我需要"],
          ["你", "Kailangan mo", "你需要"],
          ["他/她", "Kailangan niya", "他/她需要"],
          ["我們（含你）", "Kailangan natin", "我們需要"],
          ["我們（不含你）", "Kailangan namin", "我們需要"],
          ["你們", "Kailangan ninyo", "你們需要"],
          ["他們", "Kailangan nila", "他們需要"]
        ]
      }
    },
    {
      "wk": 12,
      "keyword": "Kanino",
      "reading": "卡尼諾",
      "meaning": "誰的 / 給誰 / 為誰",
      "mnemonic": "卡尼諾≈問那個卡在尼諾（誰）手上",
      "formulas": [
        "問所有：Kanino + ang + 東西？（Kanino ang aklat?）",
        "接名詞：Kaninong + 名詞？（Kaninong libro ito?）",
        "在誰那裡：Na kanino + ang + 東西？",
        "為了誰：Para kanino + ang + 東西？",
        "各自誰的：Kani-kanino（複數形）"
      ],
      "examples": [
        { "tl": "Kanino ang aklat?", "cn": "書是誰的？" },
        { "tl": "Kaninong bag ito?", "cn": "這是誰的包包？" },
        { "tl": "Para kanino ang regalo?", "cn": "禮物是為了誰的？" },
        { "tl": "Na kanino ang susi?", "cn": "鑰匙在誰那裡？" }
      ],
      "tip": "Kanino=誰的（所有）；Sino=誰（問人身份）；Ano=什麼（問物品）"
    },
    {
      "wk": 12,
      "keyword": "Kailan",
      "reading": "凱蘭",
      "meaning": "何時",
      "mnemonic": "凱蘭≈凱旋何時歸",
      "formulas": [
        "直接問時間：Kailan + ang + 事件？",
        "問幾點：Anong oras + ang + 事件？",
        "正當...時：Kung kailan + 子句",
        "無論何時：Kahit kailan",
        "永遠/從不：Kailanman（搭配否定 hindi）"
      ],
      "examples": [
        { "tl": "Kailan ang asambleya?", "cn": "大會是何時？" },
        { "tl": "Anong oras ang pagtitipon?", "cn": "聚會幾點？" },
        { "tl": "Kahit kailan, nandito ako.", "cn": "無論何時，我都在這裡。" },
        { "tl": "Hindi kailanman mababago ang katotohanan.", "cn": "真理永遠不會改變。" }
      ],
      "tip": "Anong oras 問幾點；Kailan 問哪天/哪週/哪月。別搞混！"
    },
    {
      "wk": 13,
      "keyword": "I-verb",
      "reading": "伊動詞",
      "meaning": "受詞焦點動詞，被移動的東西成為句子主角",
      "mnemonic": "i- 開頭＝「伊」要把東西交出去的動詞",
      "formulas": [
        "不定式：i- + 詞根（ituro, ibigay, iuwi, ilagay）",
        "過去式：i-in- 插入詞根前（itinuro, ibinigay）",
        "現在式：i-in- + 重複首音節（itinuturo, ibinibigay）",
        "未來式：i- + 重複首音節（ituturo, ibibigay）",
        "注意：l/r/w/y 開頭詞根用 ini- 前綴（inilagay, inirehal）"
      ],
      "examples": [
        { "tl": "Ituturo namin ang katotohanan.", "cn": "我們將教導真理。" },
        { "tl": "Ibigay mo sa kanya ang libro.", "cn": "把書給他。" },
        { "tl": "Itinuro niya ang Biblia.", "cn": "他已教導了聖經。" },
        { "tl": "Itinuturo niya ang Tagalog.", "cn": "他正在教他加祿語。" }
      ],
      "tip": "I-verb 強調被移動的東西（直接受詞）；An-verb 強調接受者（人）"
    },
    {
      "wk": 14,
      "keyword": "Ma-verb",
      "reading": "馬動詞",
      "meaning": "感受狀態動詞，表達感受、身體狀態、自發動作",
      "mnemonic": "ma- 開頭＝「馬上」感受到的狀態",
      "formulas": [
        "不定式：ma- + 詞根（makinig, matulog, maupo）",
        "過去式：na- + 詞根（nakinig, natulog）—— ma 換成 na",
        "現在式：na- + 重複首音節 + 詞根（nakikinig, natutulog）",
        "未來式：ma- + 重複首音節 + 詞根（makikinig, matutulog）"
      ],
      "examples": [
        { "tl": "Kailangan kang makinig.", "cn": "你需要聆聽。" },
        { "tl": "Nakinig siya ng mabuti.", "cn": "他聽得很好。" },
        { "tl": "Nakikinig kami ngayon.", "cn": "我們現在正在聽。" },
        { "tl": "Makikinig ka ba bukas?", "cn": "你明天會聽嗎？" }
      ],
      "tip": "ma-→na- 是記憶關鍵！過去式就把 m 換成 n：makinig→nakinig",
      "table": {
        "headers": ["時態", "Makinig（聆聽）", "說明"],
        "rows": [
          ["不定式", "Makinig", "ma- + 詞根"],
          ["過去式", "Nakinig", "na- + 詞根（m換n）"],
          ["現在式", "Nakikinig", "na- + 重複 + 詞根"],
          ["未來式", "Makikinig", "ma- + 重複 + 詞根"]
        ]
      }
    },
    {
      "wk": 15,
      "keyword": "An-verb",
      "reading": "安動詞",
      "meaning": "位置/受者焦點動詞，接受者或地點成為句子主角",
      "mnemonic": "-an 結尾＝強調「安置在誰／在哪」",
      "formulas": [
        "不定式：詞根 + -an（bigyan, tulungan, hugasan）",
        "元音結尾詞根加 -han（dalawin→dalawhan）",
        "過去式：in- + 詞根 + -an（binigyan, tinulungan）",
        "現在式：in- + 重複首音節 + -an（binibigyan, tinunutulungan）",
        "未來式：重複首音節 + 詞根 + -an（bibigyan, tutulungan）"
      ],
      "examples": [
        { "tl": "Bigyan kita ng tract.", "cn": "給你傳道冊子。" },
        { "tl": "Tulungan kita.", "cn": "我來幫助你。" },
        { "tl": "Binigyan ko siya ng libro.", "cn": "我給了他書。" },
        { "tl": "Dalawin mo ako.", "cn": "來探訪我。" }
      ],
      "tip": "An-verb vs I-verb：An-verb 強調接受者（人成為主語），I-verb 強調被給的東西（物成為主語）"
    }
  ],
